# === Lead form (Resend) ===
# Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=

# Where lead notifications are delivered (your inbox).
# Defaults to bsr12459@outlook.de in code if unset.
LEAD_TO_EMAIL=bsr12459@outlook.de

# Sender — MUST be an address on a domain verified in Resend.
LEAD_FROM_EMAIL=Clear Fix <noreply@mail.srooter.ai>

# === Admin editor (/admin) for Impressum & Datenschutz ===
# Password the site owner uses to log in at /admin. Pick a strong value.
ADMIN_PASSWORD=

# Auto-added by Vercel when you connect a Blob store to the project.
# Stores the edited legal texts. Leave blank locally to use built-in defaults.
BLOB_READ_WRITE_TOKEN=

# === Optional ===
# Canonical site URL (used for metadata/OG). Falls back to the Vercel URL,
# then https://clearfix.de.
NEXT_PUBLIC_SITE_URL=
